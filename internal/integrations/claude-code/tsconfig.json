{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@mcp-client/*": ["./mcp-client/*"],
      "@ide-extension/*": ["./ide-extension/*"],
      "@tests/*": ["./tests/*"]
    }
  },
  "include": [
    "mcp-client/**/*",
    "ide-extension/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests"
  ]
}
