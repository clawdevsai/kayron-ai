# Dockerfile.mt5-adapter - Multi-stage, Alpine, <150MB
# Stage 1: Builder (deps + protos)
FROM python:3.14-alpine as builder

WORKDIR /build

# Install build tools (minimal)
RUN apk add --no-cache gcc musl-dev protobuf-dev git

# Copy poetry files
COPY pyproject.toml poetry.lock ./

# Install dependencies to /build/venv
RUN python -m venv venv && \
    . venv/bin/activate && \
    pip install --no-cache-dir -U pip setuptools && \
    pip install --no-cache-dir poetry && \
    poetry export -o requirements.txt --without-hashes && \
    pip install --no-cache-dir -r requirements.txt

# Compile protos
COPY services/mt5-adapter/proto proto/
RUN . venv/bin/activate && \
    python -m grpc_tools.protoc \
    -I proto \
    --python_out=. \
    --grpc_python_out=. \
    proto/*.proto

# Stage 2: Runtime (minimal)
FROM python:3.14-alpine

WORKDIR /app

# Install runtime deps only (no dev tools)
RUN apk add --no-cache ca-certificates curl

# Copy venv from builder
COPY --from=builder /build/venv /app/venv

# Copy app code
COPY services/mt5-adapter/src /app/src
COPY services/mt5-adapter/proto /app/proto
COPY --from=builder /build/*_pb2*.py /app/src/

# Set env
ENV PATH=/app/venv/bin:$PATH \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# Health check
HEALTHCHECK --interval=10s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:50051/health || exit 1

# Run daemon
CMD ["python", "-m", "src.daemon"]
